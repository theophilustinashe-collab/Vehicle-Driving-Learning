{
  "name": "roadify",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "node ./scripts/dev.mjs",
    "mobile:android": "pnpm --filter @roadify/vid-master run mobile:open:android",
    "mobile:sync": "pnpm --filter @roadify/vid-master run mobile:sync",
    "setup:windows": "setup_windows.bat",
    "sync": "sync.bat"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
